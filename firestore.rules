rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is a parent of the child
    function isParentOf(childId) {
      return exists(/databases/$(database)/documents/parent_child/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/parent_child/$(request.auth.uid)).data.childId == childId;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /progress/{userId}/topics/{topicId} {
      // User can read/write their own progress
      // Parent can read their child's progress
      allow read: if isAuthenticated() && (request.auth.uid == userId || isParentOf(userId));
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /sessions/{sessionId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow creation if they assign it to themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    match /parent_child/{parentId} {
      allow read, write: if isAuthenticated() && request.auth.uid == parentId;
    }
  }
}
